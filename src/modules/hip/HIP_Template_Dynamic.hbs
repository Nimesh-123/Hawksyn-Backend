    /* ═══════════════════════════════════════════════════════════════
   HAWKSYN HIP — MOTION + POLISH LAYER
   Single consolidated block — no conflicts
═══════════════════════════════════════════════════════════════ */

    /* 22. BODY DOT GRID ─────────────────────────────────────────── */
    body {
      background-image: radial-gradient(circle, rgba(196, 127, 0, 0.028) 1px, transparent 1px);
      background-size: 28px 28px;
    }

    /* 1. THREAD — position context + pulse bead ─────────────────── */

    .thread::after {
      content: '';
      position: absolute;
      left: -1px;
      top: 0;
      width: 5px;
      height: 36px;
      border-radius: 3px;
      background: linear-gradient(180deg, transparent, #F0A500, transparent);
      animation: thread-bead 4s ease-in-out infinite;
      opacity: 0;
    }

    @keyframes thread-bead {
      0% {
        top: 0;
        opacity: 0;
      }

      8% {
        opacity: 1;
      }

      88% {
        opacity: 1;
      }

      100% {
        top: calc(100vh - 52px);
        opacity: 0;
      }
    }

    /* 2. NAV sweep + active dot ─────────────────────────────────── */
    .hdr {
      position: relative;
    }

    .hdr::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      height: 1px;
      width: 100%;
      background: linear-gradient(90deg, transparent, #C47F00, transparent);
      transform: scaleX(0);
      transform-origin: left center;
      animation: nav-sweep 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
    }

    @keyframes nav-sweep {
      to {
        transform: scaleX(1);
      }
    }

    .nav-a.active {
      color: #fff !important;
    }

    .nav-a {
      position: relative;
    }

    .nav-a.active::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 50%;
      transform: translateX(-50%);
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: #C47F00;
      box-shadow: 0 0 6px #C47F00;
    }

    /* 3. B-LINE shimmer ─────────────────────────────────────────── */
    .b-line {
      position: relative;
      overflow: hidden;
    }

    .b-line::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg,
          transparent 0%, transparent 20%,
          rgba(255, 140, 120, 0.7) 45%,
          rgba(255, 255, 200, 0.9) 50%,
          rgba(255, 140, 120, 0.7) 55%,
          transparent 80%, transparent 100%);
      background-size: 200% 100%;
      animation: bline-sweep 4s ease-in-out infinite;
    }

    @keyframes bline-sweep {
      0% {
        background-position: 200% 0;
        opacity: 0;
      }

      10% {
        opacity: 1;
      }

      90% {
        opacity: 1;
      }

      100% {
        background-position: -200% 0;
        opacity: 0;
      }
    }

    /* 4. BANNER STAR DOTS ───────────────────────────────────────── */
    .b-grid {
      position: relative;
    }

    .b-grid::before {
      content: '';
      position: absolute;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: #F0A500;
      box-shadow: 0 0 5px #F0A500;
      top: 28%;
      left: 45%;
      animation: star-blink 3.2s ease-in-out 0.8s infinite;
    }

    .b-grid::after {
      content: '';
      position: absolute;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: #C47F00;
      box-shadow: 0 0 4px #C47F00;
      top: 55%;
      left: 68%;
      animation: star-blink 4.1s ease-in-out 2.1s infinite;
    }

    .b-orb3 {
      position: relative;
    }

    .b-orb3::before {
      content: '';
      position: absolute;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: #C47F00;
      box-shadow: 0 0 4px #C47F00;
      top: 70%;
      left: 25%;
      animation: star-blink 5.3s ease-in-out 1.4s infinite;
    }

    .b-orb3::after {
      content: '';
      position: absolute;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: #F0A500;
      box-shadow: 0 0 5px #F0A500;
      top: 30%;
      left: 80%;
      animation: star-blink 3.8s ease-in-out 0.3s infinite;
    }

    @keyframes star-blink {

      0%,
      100% {
        opacity: 0.15;
        transform: scale(1);
      }

      50% {
        opacity: 0.9;
        transform: scale(1.4);
      }
    }

    /* 5. AVATAR rotating ring ───────────────────────────────────── */
    .avatar-wrap::before {
      content: '';
      position: absolute;
      inset: -7px;
      border-radius: 50%;
      background: conic-gradient(from 0deg,
          transparent 0deg, transparent 200deg,
          rgba(196, 127, 0, 0.5) 240deg,
          rgba(240, 165, 0, 0.9) 270deg,
          rgba(196, 127, 0, 0.5) 300deg,
          transparent 340deg, transparent 360deg);
      animation: avatar-ring 8s linear infinite;
      z-index: 0;
    }

    .avatar-wrap::after {
      content: '';
      position: absolute;
      inset: -4px;
      border-radius: 50%;
      background: #fff;
      z-index: 1;
    }

    .avatar-wrap .avatar {
      z-index: 2;
      position: relative;
    }

    .avatar-wrap @keyframes avatar-ring {
      to {
        transform: rotate(360deg);
      }
    }

    .avatar-wrap:hover::before {
      animation-play-state: paused;
    }

    /* 6. VERIFIED BADGE pulse ring ──────────────────────────────── */

    .avatar-verified::after {
      content: '';
      position: absolute;
      inset: -3px;
      border-radius: 50%;
      border: 2px solid rgba(76, 175, 80, 0.5);
      animation: badge-ring 2.5s ease-out infinite;
    }

    @keyframes badge-ring {
      0% {
        transform: scale(1);
        opacity: 0.8;
      }

      100% {
        transform: scale(1.9);
        opacity: 0;
      }
    }

    /* 7. PTAG staggered load-in ─────────────────────────────────── */
    .profile-tags .ptag {
      opacity: 0;
      transform: translateY(10px);
      animation: tag-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .profile-tags .ptag:nth-child(1) {
      animation-delay: 0.55s;
    }

    .profile-tags .ptag:nth-child(2) {
      animation-delay: 0.65s;
    }

    .profile-tags .ptag:nth-child(3) {
      animation-delay: 0.75s;
    }

    .profile-tags .ptag:nth-child(4) {
      animation-delay: 0.85s;
    }

    .profile-tags .ptag:nth-child(5) {
      animation-delay: 0.95s;
    }

    @keyframes tag-in {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* 8. PSTAT number hover scale + amber underline ─────────────── */
    .pstat-val {
      display: block;
      transition: transform 0.2s, color 0.2s;
    }

    .pstat:hover .pstat-val {
      transform: scale(1.06);
      color: #C47F00;
    }

    .pstat-val::after {
      content: '';
      display: block;
      height: 2px;
      width: 0;
      margin: 3px auto 0;
      background: linear-gradient(90deg, transparent, #C47F00, transparent);
      border-radius: 1px;
      transition: width 0.25s ease;
    }

    .pstat:hover .pstat-val::after {
      width: 70%;
    }

    /* 9. VER-CARD left edge breath ──────────────────────────────── */

    .ver-card::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: linear-gradient(180deg, #C47F00, #F0A500, #C47F00);
      animation: ver-breath 3s ease-in-out infinite;
      z-index: 2;
    }

    @keyframes ver-breath {

      0%,
      100% {
        opacity: 0.25;
      }

      50% {
        opacity: 0.9;
      }
    }

    /* 10. VER-ICON-WRAP slow spin ───────────────────────────────── */
    .ver-icon-wrap {
      animation: icon-spin 20s linear infinite;
    }

    @keyframes icon-spin {
      to {
        transform: rotate(360deg);
      }
    }

    /* 12. CHAPTER DIVIDER beacon + line reveal ──────────────────── */
    .ch-divider {
      position: relative;
    }

    .ch-divider::before {
      content: '';
      display: inline-block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #C47F00;
      box-shadow: 0 0 8px rgba(196, 127, 0, 0.6);
      flex-shrink: 0;
      animation: beacon 2.8s ease-in-out infinite;
    }

    @keyframes beacon {

      0%,
      100% {
        box-shadow: 0 0 4px rgba(196, 127, 0, 0.4);
        transform: scale(1);
      }

      50% {
        box-shadow: 0 0 12px rgba(196, 127, 0, 0.8), 0 0 20px rgba(196, 127, 0, 0.3);
        transform: scale(1.2);
      }
    }

    .ch-divider::after {
      content: '';
      flex: 1;
      height: 0.5px;
      background: linear-gradient(90deg, #D0CCC4, transparent);
      transform: scaleX(0);
      transform-origin: left center;
      transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s;
    }

    .ch-divider.visible::after {
      transform: scaleX(1);
    }

    /* 13+SH. SECTION HEADER — black 3D + bead ───────────────────── */
    .sh {
      padding: 14px 20px;
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(ellipse at 0% 0%, rgba(255, 255, 255, 0.07) 0%, transparent 50%),
        radial-gradient(ellipse at 100% 100%, rgba(196, 127, 0, 0.12) 0%, transparent 55%),
        linear-gradient(160deg, #2A2520 0%, #1A1612 40%, #0D0B08 100%) !important;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        inset 0 -1px 0 rgba(0, 0, 0, 0.5),
        inset 3px 0 0 #C47F00,
        0 2px 8px rgba(0, 0, 0, 0.18) !important;
      border-left: none !important;
      border-top: 0.5px solid rgba(255, 255, 255, 0.06) !important;
      border-right: 0.5px solid rgba(255, 255, 255, 0.04) !important;
      border-bottom: 0.5px solid rgba(0, 0, 0, 0.3) !important;
      transition: background 0.2s, box-shadow 0.2s;
    }

    .sh::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(118deg,
          rgba(255, 255, 255, 0.05) 0%,
          transparent 40%,
          transparent 60%,
          rgba(196, 127, 0, 0.04) 100%);
      pointer-events: none;
      z-index: 1;
    }

    .sh::before {
      content: '';
      position: absolute;
      left: 0;
      top: -20px;
      width: 3px;
      height: 20px;
      background: linear-gradient(180deg, transparent, rgba(240, 165, 0, 0.9), transparent);
      animation: sh-bead 4s ease-in-out infinite;
      z-index: 3;
      pointer-events: none;
    }

    @keyframes sh-bead {
      0% {
        top: -20px;
        opacity: 0;
      }

      10% {
        opacity: 1;
      }

      90% {
        opacity: 0.7;
      }

      100% {
        top: 100%;
        opacity: 0;
      }
    }

    .sh-meta,
    .sh-title {
      position: relative;
      z-index: 2;
    }

    .sh-title {
      color: #F0EDE8 !important;
    }

    .sh-ref {
      color: #F0A500 !important;
    }

    .sh-ch {
      color: rgba(255, 255, 255, 0.38) !important;
    }

    .card:hover .sh {
      background:
        radial-gradient(ellipse at 0% 0%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse at 100% 100%, rgba(196, 127, 0, 0.18) 0%, transparent 55%),
        linear-gradient(160deg, #312B24 0%, #201C15 40%, #110E09 100%) !important;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        inset 0 -1px 0 rgba(0, 0, 0, 0.6),
        inset 3px 0 0 #F0A500,
        0 3px 12px rgba(0, 0, 0, 0.25) !important;
    }

    /* 14. IC card entry shimmer ─────────────────────────────────── */

    .ic::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, rgba(196, 127, 0, 0), transparent);
      transition: background 0.25s;
      z-index: 1;
    }

    .ic.lit::before {
      background: linear-gradient(90deg, transparent, rgba(196, 127, 0, 0.5), transparent);
      background-size: 200% 100%;
      animation: ic-entry 0.7s ease-out forwards;
    }

    @keyframes ic-entry {
      from {
        background-position: 150% 0;
      }

      to {
        background-position: -50% 0;
      }
    }

    .ic:hover::before {
      background: linear-gradient(90deg, transparent, rgba(196, 127, 0, 0.35), transparent);
    }

    /* 16. STR-CARD dot texture + border breath ──────────────────── */
    .str-card {
      background-image:
        radial-gradient(circle, rgba(0, 0, 0, 0.07) 1px, transparent 1px),
        linear-gradient(135deg, #C47F00, #C47F00);
      background-size: 20px 20px, 100% 100%;
      animation: str-border 4s ease-in-out infinite;
    }

    @keyframes str-border {

      0%,
      100% {
        border-color: #A86D00;
      }

      50% {
        border-color: #D99500;
      }
    }

    /* 17. TICKER pause on hover + edge fade masks ───────────────── */
    .ticker-card:hover .ticker-track {
      animation-play-state: paused;
    }

    .ticker-wrap {
      -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%);
      mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%);
    }

    /* 18. CERT-CARD top border travelling shine ─────────────────── */
    .cert-card {
      position: relative;
      overflow: hidden;
    }

    .cert-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg,
          transparent 0%, #C47F00 30%,
          #F0A500 45%, rgba(255, 140, 120, 0.9) 50%,
          #F0A500 55%, #C47F00 70%, transparent 100%);
      background-size: 200% 100%;
      animation: cert-shine 3s ease-in-out infinite;
      z-index: 2;
    }

    @keyframes cert-shine {
      0% {
        background-position: 150% 0;
      }

      100% {
        background-position: -150% 0;
      }
    }

    /* 19. CERT fingerprint terminal blink ───────────────────────── */
    .cert-fp::after {
      content: '█';
      font-size: 9px;
      color: rgba(196, 127, 0, 0.6);
      animation: cursor-blink 1.1s step-end infinite;
      margin-left: 2px;
      vertical-align: middle;
    }

    @keyframes cursor-blink {

      0%,
      100% {
        opacity: 1;
      }

      50% {
        opacity: 0;
      }
    }

    /* 20. GL-CARD left border hover bead ────────────────────────── */
    .gl-card {
      position: relative;
      overflow: hidden;
    }

    .gl-card::before {
      content: '';
      position: absolute;
      left: 0;
      top: -24px;
      width: 3px;
      height: 24px;
      background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.8), transparent);
      opacity: 0;
    }

    .gl-card:hover::before {
      opacity: 1;
      animation: gl-bead 0.55s ease-out forwards;
    }

    @keyframes gl-bead {
      from {
        top: -24px;
      }

      to {
        top: 110%;
      }
    }

    /* 21. FOOTER amber corner glow + brand pulse ────────────────── */

    .footer-card::after {
      content: '';
      position: absolute;
      bottom: -60px;
      right: -60px;
      width: 200px;
      height: 200px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(196, 127, 0, 0.08) 0%, transparent 70%);
      pointer-events: none;
    }

    .footer-wordmark span {
      animation: brand-pulse 4s ease-in-out infinite;
    }

    @keyframes brand-pulse {

      0%,
      100% {
        opacity: 0.85;
      }

      50% {
        opacity: 1;
        text-shadow: 0 0 12px rgba(196, 127, 0, 0.4);
      }
    }

    /* CARD global hover glow ─────────────────────────────────────── */
    .card:hover {
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.09), 0 0 0 0.5px rgba(196, 127, 0, 0.12);
    }

    /* REDUCED MOTION ─────────────────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {

      .thread::after,
      .hdr::after,
      .b-line::after,
      .b-grid::before,
      .b-grid::after,
      .b-orb3::before,
      .b-orb3::after,
      .avatar-wrap::before,
      .avatar-verified::after,
      .profile-tags .ptag,
      .ver-card::before,
      .ver-icon-wrap,
      .sh::before,
      .str-card,
      .cert-card::before,
      .cert-fp::after,
      .footer-wordmark span,
      .ch-divider::before {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }

      .profile-tags .ptag {
        opacity: 1;
        transform: none;
      }

      .ch-divider::after {
        transform: scaleX(1);
      }
    }


    .ic:hover .ic-tag {
      background: #2E2B26;
      border-color: rgba(196, 127, 0, 0.35);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2)
    }

    .chip:hover {
      background: #2E2B26;
      border-color: rgba(196, 127, 0, 0.35);
      transform: translateY(-1px);
      box-shadow: 0 3px 10px rgba(0, 0, 0, 0.18)
    }

    .footer-version {
      font-size: 10px;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.2);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border: 0.5px solid rgba(255, 255, 255, 0.1);
      border-radius: 20px;
      padding: 3px 10px;
    }

    /* ── MOBILE RESPONSIVENESS ─────────────────────────────────── */
    @media (max-width: 768px) {
      .hdr {
        height: auto;
        flex-direction: column;
        padding: 12px 16px;
        gap: 10px;
      }

      .hdr-nav {
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
      }

      .drop {
        width: 100vw;
        max-width: 300px;
        left: 50%;
        transform: translateX(-50%);
      }

      .page {
        padding: 10px 12px 0;
      }

      .main {
        width: 100%;
      }

      .banner {
        height: 120px;
      }

      .avatar-row {
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-top: -40px;
        gap: 12px;
      }

      .avatar {
        width: 80px;
        height: 80px;
      }

      .avatar-actions {
        justify-content: center;
      }

      {{!-- .profile-tags {
        justify-content: center;
      } --}}

      .profile-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
      }
      .pstat {
        border-right: 0.5px solid #EBEBEB;
        border-bottom: 0.5px solid #EBEBEB;
        padding: 16px 10px;
      }
      .pstat:nth-child(even) {
        border-right: none;
      }
      .pstat:last-child {
        grid-column: span 2;
        border-right: none;
        border-bottom: none;
      }
      .pstat:nth-last-child(2):nth-child(odd) {
        border-bottom: none;
      }

      .ptag {
        font-size: 9px;
        padding: 4px 8px;
      }

      .ver-card {
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .ver-left {
        flex-direction: column;
      }

      .cc-text,
      .sc-text {
        font-size: 13px;
        line-height: 1.5;
        min-height: auto;
      }
      .sec-prose {
        font-size: 12px;
        line-height: 1.5;
        padding: 16px 14px 20px;
      }
      .hl-desc {
        font-size: 11px;
      }
      .chip-row {
        gap: 6px;
        margin-top: 12px;
      }
      .chip {
        font-size: 9px;
        padding: 4px 10px;
      }

      .hl-num,
      .sc-num {
        font-size: 36px;
      }

      .sec-grid,
      .hl-grid,
      .gl-grid {
        grid-template-columns: 1fr;
      }

      .sec-scale {
        grid-template-columns: 1fr;
      }

      .sc-col {
        border-right: none;
        border-bottom: 0.5px solid #F0EDE6;
      }

      .sc-col:last-child {
        border-bottom: none;
      }

      .cert-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
      }

      .footer-top {
        flex-direction: row;
        flex-wrap: wrap;
        align-items: flex-start;
        text-align: left;
        gap: 24px;
      }
      .footer-brand-block {
        width: 100%;
      }
      .footer-links-col {
        flex: 1;
        {{!-- min-width: 120px; --}}
      }

      .footer-bottom {
        flex-direction: column;
        justify-content: flex-start;
        text-align: left;
        align-items: flex-start;
        gap: 12px;
      }
      
      .footer-cert {
        align-items: flex-start;
      }
      .footer-cert-dot {
        margin-top: 4px;
        flex-shrink: 0;
      }

      .thread {
        display: none;
      }
    }
    /* ── RESPONSIVE DESIGN (MOBILE) ────────────────────────────── */
    @media (max-width: 768px) {
      .thread { display: none; }
      .page { padding: 12px 14px 0; }
      .main { width: 100%; max-width: 100%; }
      
      /* Dropdown specific fixes: span full width of header and remove relative positioning from items */
      .hdr { padding: 12px 14px; position: relative; }
      .nav-item { position: static; }
      .drop {
        width: auto !important;
        max-width: none !important;
        left: 14px !important;
        right: 14px !important;
        transform: none !important;
        top: calc(100% + 5px) !important;
        min-width: 0 !important;
        z-index: 300;
      }
      .hdr-nav { gap: 6px; }
      .nav-a { padding: 5px 6px; font-size: 11px; }

      .avatar-row { flex-direction: column; align-items: flex-start; gap: 12px; margin-top: -30px; position: relative; z-index: 10; }
      .avatar-wrap { transform: scale(0.85); transform-origin: left bottom; }
      .profile-name { font-size: 28px; }
      
      .sec-grid { grid-template-columns: 1fr; }
      .hl-grid { grid-template-columns: 1fr; }
      .sec-scale { grid-template-columns: 1fr; }
      .sc-col { border-right: none; border-bottom: 0.5px solid #F0EDE6; }
      .sc-col:last-child { border-bottom: none; }
      .gl-grid { grid-template-columns: 1fr; }
    }
    @media print {
      .reveal {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
      .profile-name .char {
        opacity: 1 !important;
        transform: none !important;
        animation: none !important;
      }
      * {
        transition: none !important;
        animation: none !important;
      }
    }
  </style>
</head>

<body>

  <div class="thread"></div>

  {{#unless isPdf}}
  <header class="hdr">
    <div class="hdr-name">{{PROFILE.full_name}}</div>
    <nav class="hdr-nav">
      <div class="nav-item">
        <div class="nav-a">Profile <span class="arr">▾</span></div>
        <div class="drop">
          <div class="drop-g">Profile</div>
          <div class="drop-i">Identity Summary</div>
          <div class="drop-i">Seniority Signal</div>
          <div class="drop-i">Career Pattern</div>
          <div class="drop-hr"></div>
          <div class="drop-g">Impact</div>
          <div class="drop-i">Measurable Impact</div>
          <div class="drop-i">Scale of Responsibility</div>
          <div class="drop-i">What Career Never Said</div>
          <div class="drop-i">Decision Authority</div>
        </div>
      </div>
      <div class="nav-item">
        <div class="nav-a">Expertise <span class="arr">▾</span></div>
        <div class="drop">
          <div class="drop-g">Strengths</div>
          <div class="drop-i">Professional Strengths</div>
          <div class="drop-i">Depth Map</div>
          <div class="drop-i">Domain Authority</div>
          <div class="drop-hr"></div>
          <div class="drop-g">Growth</div>
          <div class="drop-i">Growth Arc</div>
          <div class="drop-i">How Padma Moved</div>
          <div class="drop-i">Employer Pedigree</div>
          <div class="drop-i">Domain Accumulation</div>
        </div>
      </div>
      <div class="nav-item">
        <div class="nav-a">Leadership <span class="arr">▾</span></div>
        <div class="drop">
          <div class="drop-g">Character</div>
          <div class="drop-i">Leadership Signals</div>
          <div class="drop-i">Trust Signals</div>
          <div class="drop-hr"></div>
          <div class="drop-g">Market</div>
          <div class="drop-i">Market Demand</div>
          <div class="drop-i">Distinctive Edge</div>
        </div>
      </div>
      <div class="nav-ver">Verify</div>
      <button class="hdr-cta">Download CV</button>
    </nav>
  </header>
  {{/unless}}

  <div class="page">
    <div class="main">
    {{resetCounter}}

      <!-- ── PROFILE HERO CARD ── -->
      <div class="card reveal">
        <div class="banner">
          <div class="b-grid"></div>
          <div class="b-orb1"></div>
          <div class="b-orb2"></div>
          <div class="b-orb3"></div>
          <svg viewBox="0 0 860 168" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 120 Q 215 40 430 100 T 860 60" fill="none" stroke="rgba(196,127,0,0.35)" stroke-width="2" />
            <path d="M0 140 Q 215 60 430 120 T 860 80" fill="none" stroke="rgba(196,127,0,0.18)" stroke-width="1.5" />
            <path d="M0 80 Q 215 140 430 60 T 860 120" fill="none" stroke="rgba(196,127,0,0.2)" stroke-width="1.5" />
            <path d="M0 60 Q 150 100 300 50 T 600 90 T 860 40" fill="none" stroke="rgba(240,165,0,0.12)"
              stroke-width="1" />
            <circle cx="215" cy="70" r="3" fill="#C47F00" opacity="0.7" />
            <circle cx="430" cy="100" r="4" fill="#F0A500" opacity="0.9" />
            <circle cx="645" cy="75" r="3" fill="#C47F00" opacity="0.6" />
            <circle cx="100" cy="110" r="2" fill="#F0A500" opacity="0.5" />
            <circle cx="760" cy="95" r="2.5" fill="#C47F00" opacity="0.55" />
            <circle cx="320" cy="55" r="2" fill="#F0A500" opacity="0.4" />
            <circle cx="550" cy="115" r="2" fill="#C47F00" opacity="0.4" />
            <line x1="180" y1="24" x2="180" y2="48" stroke="rgba(196,127,0,0.3)" stroke-width="1.5" />
            <line x1="380" y1="14" x2="380" y2="38" stroke="rgba(196,127,0,0.25)" stroke-width="1.5" />
            <line x1="580" y1="24" x2="580" y2="48" stroke="rgba(196,127,0,0.3)" stroke-width="1.5" />
            <line x1="780" y1="14" x2="780" y2="38" stroke="rgba(196,127,0,0.2)" stroke-width="1.5" />
            <line x1="700" y1="0" x2="860" y2="60" stroke="rgba(196,127,0,0.08)" stroke-width="12" />
            <line x1="760" y1="0" x2="860" y2="40" stroke="rgba(196,127,0,0.05)" stroke-width="12" />
            <ellipse cx="56" cy="80" rx="30" ry="18" fill="none" stroke="rgba(196,127,0,0.28)" stroke-width="1.5" />
            <circle cx="56" cy="80" r="6" fill="none" stroke="rgba(196,127,0,0.4)" stroke-width="1.5" />
            <circle cx="56" cy="80" r="2.5" fill="rgba(196,127,0,0.6)" />
            <circle cx="56" cy="80" r="10" fill="none" stroke="rgba(196,127,0,0.1)" stroke-width="1" />
          </svg>
          <div class="b-line"></div>
          <div class="b-mark">hawksyn</div>
        </div>
        <div class="profile-body">
          <div class="avatar-row">
            <div class="avatar-wrap">
              <div class="avatar">
                {{#if PROFILE.profilePhoto}}
                <img src="{{PROFILE.profilePhoto}}" alt="Profile Photo" />
                {{else}}
                <div class="avatar-fallback">{{PROFILE.first_name.[0]}}{{PROFILE.last_name.[0]}}</div>
                {{/if}}
              </div>
              <div class="avatar-verified">✓</div>
            </div>
            {{#unless isPdf}}
              <div class="avatar-actions">
              <button class="btn-dark">Share Profile</button>
              <button class="btn-amber">Download CV</button>
            </div>
            {{/unless}}
          </div>
          <div class="profile-name" id="pname"></div>
          <div class="profile-headline"><strong>{{PROFILE.current_title}}</strong>&nbsp;·&nbsp;GCC&nbsp;·&nbsp;Insurance
            Actuarial&nbsp;·&nbsp;{{PROFILE.years_experience}} years</div>
          <div class="profile-tags">
            <span class="ptag">Banking Operations</span>
            <span class="ptag">GCC</span>
            <span class="ptag">Insurance Actuarial</span>
            <span class="ptag">P&amp;L Leadership</span>
            <span class="ptag">Multi-Region</span>
          </div>
          <div class="profile-stats">
            <div class="pstat">
              <div class="pstat-val">{{PROFILE.traits_evaluated}}</div>
              <div class="pstat-key">Traits Evaluated</div>
            </div>
            <div class="pstat">
              <div class="pstat-val">{{PROFILE.strong_signals}}</div>
              <div class="pstat-key">Strong Signals</div>
            </div>
            <div class="pstat">
              <div class="pstat-val">{{PROFILE.years_experience}}</div>
              <div class="pstat-key">Years Experience</div>
            </div>
            <div class="pstat">
              <div class="pstat-val">{{PROFILE.rarity_score}}<span class="pstat-sup">%</span></div>
              <div class="pstat-key">Profile Rarity</div>
            </div>
            <div class="pstat">
              <div class="pstat-val">{{PROFILE.partial_matches}}</div>
              <div class="pstat-key">Partial Matches</div>
            </div>
          </div>
          <!-- ── VERIFICATION STRIP ── -->
          <div class="card ver-card reveal">
            <div class="ver-left">
              <div class="ver-icon-wrap">✦</div>
              <div>
                <div class="ver-title">Evidence-based profile &middot; Built from career record &middot; Not
                  self-reported</div>
                <div class="ver-sub">9 Jun 2026 &middot; Run ID: HIP_0026 &middot; 330 archetypes evaluated &middot;
                  Hawksyn PSDE</div>
              </div>
            </div>
            <div class="ver-badge">
              <div class="ver-dot"></div>Verified
            </div>
          </div>

          <!-- ── QUOTE CAROUSEL ── -->
          <div class="card carousel-card reveal">
            <div class="cc-body">
              <div class="cc-label">Career story</div>
              <span class="cc-quote">&ldquo;</span>
              {{#if isPdf}}
              <div class="cc-text pdf-static" style="display:flex; flex-direction:column; gap:16px;">
                {{#if hip.s04.prose}}<div>{{hip.s04.prose}}</div>{{/if}}
                {{#if hip.s05.prose}}<div>{{hip.s05.prose}}</div>{{/if}}
                {{#if hip.s06.prose}}<div>{{hip.s06.prose}}</div>{{/if}}
                {{#if hip.s07.prose}}<div>{{hip.s07.prose}}</div>{{/if}}
                {{#if hip.s08.prose}}<div>{{hip.s08.prose}}</div>{{/if}}
              </div>
              {{else}}
              <div class="cc-text" id="cctxt"></div>
              <div class="cc-nav">
                <div class="cc-dots" id="ccdots"></div>
                <div class="cc-prog">
                  <div class="cc-bar" id="ccbar"></div>
                </div>
                <span class="cc-ctr" id="ccctr">1 / 5</span>
              </div>
              {{/if}}
            </div>
          </div>

          <!-- ── CHAPTER 1 ── -->
          <div class="ch-divider">Chapter 1 &middot; What Stands Out</div>

          {{#if hip.s01.cards}}
          <div class="card reveal">
            <div class="card-head">
              <div class="sh" id="s01">
                <div class="sh-meta"><span class="sh-ref">Ch 1 — S01</span><span class="sh-ch">What Stands Out</span>
                </div>
                <div class="sh-title">Distinctive Edge</div>
              </div>
            </div>
            <div class="hl-body">
              <div class="hl-grid">
                {{#each hip.s01.cards}}
                <div class="hl-card {{#if @first}}feat{{/if}}">
                  <div class="hl-lbl">{{this.label}}</div>
                  <div class="hl-title"><strong>{{this.title}}</strong></div>
                  <div class="hl-desc">{{this.description}}</div>
                </div>
                {{/each}}
              </div>
            </div>
          </div>
          {{/if}}

          <!-- Strengths Carousel -->
          <div class="card str-card reveal">
            <div class="sc-body">
              <div class="sc-label">Professional strengths</div>
              {{#unless isPdf}}
              <div class="sc-counter-wrap"><span class="sc-badge" id="sc-badge">01 / 04</span><span
                  class="sc-of">Strength highlighted</span></div>
              {{/unless}}
              {{#if isPdf}}
              <div class="sc-text pdf-static" style="display:flex; flex-direction:column; gap:16px;">
                {{#if hip.s11.cards.[0].description}}<div>{{hip.s11.cards.[0].description}}</div>{{/if}}
                {{#if hip.s11.cards.[1].description}}<div>{{hip.s11.cards.[1].description}}</div>{{/if}}
                {{#if hip.s12.cards.[0].description}}<div>{{hip.s12.cards.[0].description}}</div>{{/if}}
                {{#if hip.s12.cards.[1].description}}<div>{{hip.s12.cards.[1].description}}</div>{{/if}}
              </div>
              {{else}}
              <div class="sc-text" id="sctxt">Padma brings <span class="blk">specialist actuarial depth</span> including
                IBNR, ULAE, GLM and Chain Ladder that fewer than 4% of operations professionals at her level carry.
                <span class="wdm">A rare combination of operational scale and technical expertise.</span></div>
              <div class="sc-nav">
                <div class="sc-dots" id="scdots"></div>
                <div class="sc-prog">
                  <div class="sc-bar" id="scbar"></div>
                </div>
                <span class="sc-ctr" id="scctr">1 / 4</span>
              </div>
              {{/if}}
            </div>
          </div>

          {{#each dynamicChapters}}
          <div class="ch-divider">Chapter {{this.chapterIndex}} &middot; {{this.chapterName}}</div>
          {{resetCounter}}

          {{#each this.sections}}
          <div class="card reveal">
            <div class="sh" id="{{this.id}}">
              <div class="sh-meta">
                <span class="sh-ref">Ch {{../chapterIndex}} &middot; S{{this.padId}}</span>
                <span class="sh-ch">{{../chapterName}}</span>
              </div>
              <div class="sh-title">{{this.title}}</div>
            </div>
            
            {{#if this.data.cards}}
            <div class="sec-grid">
              {{#each this.data.cards}}
              <div class="ic">
                <div class="ic-label">{{this.label}}</div>
                <div class="ic-title">{{this.title}}</div>
                <div class="ic-desc">{{this.description}}</div>
                {{#if this.tag}}<span class="ic-tag">{{this.tag}}</span>{{/if}}
              </div>
              {{/each}}
            </div>
            {{else if this.data.prose}}
            <div class="sec-prose">
              <p>{{this.data.prose}}</p>
              {{#if this.data.chips}}
              <div class="chip-row">
                {{#each this.data.chips}}
                <span class="chip">{{this}}</span>
                {{/each}}
              </div>
              {{/if}}
            </div>
            {{else if this.data.columns}}
            <div class="sec-grid">
              {{#each this.data.columns}}
              <div class="ic">
                <div class="ic-label">{{this.label}}</div>
                <div class="ic-title">{{this.value}} {{this.unit}}</div>
                <div class="ic-desc">{{this.context}}</div>
                {{#if this.chip}}<span class="ic-tag">{{this.chip}}</span>{{/if}}
              </div>
              {{/each}}
            </div>
            {{/if}}
          </div>
          {{/each}}
          {{/each}}
          <!-- Footer -->
          <div class="footer-card">
            <div class="footer-top">
              <div class="footer-brand-block">
                <div class="footer-wordmark">Hawk<span>syn</span></div>
                <div class="footer-tagline">Evidence-led validation for high-stakes professional decisions. Built by
                  Hyumeans Private Limited.</div>
              </div>
              <div class="footer-links-col">
                <div class="footer-links-title">Profile</div>
                <div class="footer-link">Download CV</div>
                <div class="footer-link">Verify Profile</div>
                <div class="footer-link">Share</div>
              </div>
              <div class="footer-links-col">
                <div class="footer-links-title">Hawksyn</div>
                <div class="footer-link">About</div>
                <div class="footer-link">How It Works</div>
                <div class="footer-link">hawksyn.com</div>
              </div>
            </div>
            <div class="footer-divider"></div>
            <div class="footer-bottom">
              <div class="footer-meta">© 2026 Hyumeans Private Limited · DIPP246851 · Ahmedabad</div>
              <div class="footer-version">v1.0</div>
              <div class="footer-cert">
                <div class="footer-cert-dot"></div>Verified Profile · Run ID: HIP_0026 · 9 Jun 2026
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

    <script>


      const nm = "{{PROFILE.full_name}}", nel = document.getElementById('pname');
      let d = 180; nm.split('').forEach((c, i) => { if (c === ' ') { const s = document.createElement('span'); s.className = 'spc'; nel.appendChild(s); d += 12; return; } const s = document.createElement('span'); s.className = 'char'; s.textContent = c; s.style.animationDelay = (d + i * 38) + 'ms'; nel.appendChild(s); });
      const obs = new IntersectionObserver(entries => { entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }); }, { threshold: 0, rootMargin: '0px 0px -30px 0px' });
      document.querySelectorAll('.reveal').forEach((el, i) => { el.style.transitionDelay = (i * 0.05) + 's'; obs.observe(el); });
      {{#unless isPdf}}
      const ccS = [
        "{{hip.s04.prose}}",
        "{{hip.s05.prose}}",
        "{{hip.s06.prose}}",
        "{{hip.s07.prose}}",
        "{{hip.s08.prose}}"
      ].filter(Boolean);
      let cci = 0; const cct = document.getElementById('cctxt'), ccd = document.getElementById('ccdots'), ccb = document.getElementById('ccbar'), ccc = document.getElementById('ccctr');
      ccS.forEach((_, i) => { const d = document.createElement('span'); d.className = 'cc-dot' + (i === 0 ? ' on' : ''); d.onclick = () => ccGo(i); ccd.appendChild(d); });
      let ccP = 0, ccI; function ccSP() { clearInterval(ccI); ccP = 0; ccb.style.width = '0%'; ccI = setInterval(() => { ccP += 100 / (5000 / 100); if (ccP >= 100) ccP = 100; ccb.style.width = ccP + '%'; }, 100); }
      function ccGo(i) { cct.classList.add('out'); setTimeout(() => { cci = i; cct.innerHTML = ccS[cci]; cct.classList.remove('out'); cct.classList.add('in'); setTimeout(() => cct.classList.remove('in'), 40); document.querySelectorAll('.cc-dot').forEach((d, j) => d.classList.toggle('on', j === cci)); ccc.textContent = (cci + 1) + ' / ' + ccS.length; ccSP(); }, 300); }
      if (ccS.length) cct.innerHTML = ccS[0]; ccSP(); setInterval(() => ccGo((cci + 1) % ccS.length), 5000);
      const scS = [
        "{{hip.s11.cards.[0].description}}",
        "{{hip.s11.cards.[1].description}}",
        "{{hip.s12.cards.[0].description}}",
        "{{hip.s12.cards.[1].description}}"
      ].filter(Boolean);
      let sci = 0; const sct = document.getElementById('sctxt'), scd = document.getElementById('scdots'), scb = document.getElementById('scbar'), scc = document.getElementById('scctr'), scbadge = document.getElementById('sc-badge');
      scS.forEach((_, i) => { const d = document.createElement('span'); d.className = 'sc-dot' + (i === 0 ? ' on' : ''); d.onclick = () => scGo(i); scd.appendChild(d); });
      let scP = 0, scI; function scSP() { clearInterval(scI); scP = 0; scb.style.width = '0%'; scI = setInterval(() => { scP += 100 / (5000 / 100); if (scP >= 100) scP = 100; scb.style.width = scP + '%'; }, 100); }
      function scGo(i) { sct.classList.add('out'); setTimeout(() => { sci = i; sct.innerHTML = scS[sci]; sct.classList.remove('out'); sct.classList.add('in'); setTimeout(() => sct.classList.remove('in'), 40); document.querySelectorAll('.sc-dot').forEach((d, j) => d.classList.toggle('on', j === sci)); scc.textContent = (sci + 1) + ' / ' + scS.length; const pad = n => n < 10 ? '0' + n : n; scbadge.textContent = pad(sci + 1) + ' / ' + pad(scS.length); scSP(); }, 300); }
      if (scS.length) sct.innerHTML = scS[0]; scSP(); setInterval(() => scGo((sci + 1) % scS.length), 5000);
      {{/unless}}



      // ── IC card entry shimmer ─────────────────────────────────────
      const icObs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('lit'); icObs.unobserve(e.target); }
        });
      }, { threshold: 0.15 });
      document.querySelectorAll('.ic').forEach(el => icObs.observe(el));

      // ── Chapter divider line reveal ───────────────────────────────
      const chObs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('visible'); chObs.unobserve(e.target); }
        });
      }, { threshold: 0.4 });
      document.querySelectorAll('.ch-divider').forEach(el => chObs.observe(el));

      // ── Count-up 0→{{PROFILE.traits_evaluated}} on featured hl-card ───────────────────────
      (function () {
        const el = document.querySelector('.hl-card.feat .hl-num');
        if (!el) return;
        let started = false;
        const obs = new IntersectionObserver(entries => {
          if (!entries[0].isIntersecting || started) return;
          started = true;
          const t0 = performance.now(), dur = 1200, target = {{PROFILE.traits_evaluated}} || 0;
        const tick = now => {
          const p = Math.min((now - t0) / dur, 1);
          el.textContent = Math.round((1 - Math.pow(1 - p, 3)) * target);
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        obs.disconnect();
      }, { threshold: 0.6 });
      obs.observe(el.closest('.hl-card'));
}) ();

      // ── Active nav dot on scroll ──────────────────────────────────
      (function () {
        const map = {
          s01: 0, s02: 0, s03: 0, s04: 1, s05: 1, s06: 1,
          s07: 2, s08: 2, s09: 2, s10: 2, s11: 3, s12: 3, s13: 3, s14: 3,
          s15: 4, s16: 4, s17: 4, s18: 4, s19: 5, s21: 5, s22: 5,
          s23: 6, s24: 6, s25: 6
        };
        const links = document.querySelectorAll('.nav-a');
        const secObs = new IntersectionObserver(entries => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              const idx = map[e.target.id];
              if (idx !== undefined)
                links.forEach((l, i) => l.classList.toggle('active', i === idx));
            }
          });
        }, { threshold: 0.35 });
        Object.keys(map).forEach(id => {
          const el = document.getElementById(id);
          if (el) secObs.observe(el);
        });
      })();

    </script>
</body>

</html>