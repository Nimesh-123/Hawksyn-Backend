<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>{{PROFILE.full_name}} · Hawksyn Intelligence Profile</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;1,14..32,400&display=swap"
    rel="stylesheet">
  <style>
    /* ── RESET ─────────────────────────────────────────────────── */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    html,
    body {
      width: 100%;
      background: #EDEAE3;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      color: #1A1A1A
    }

    /* ── VERTICAL AMBER THREAD ─────────────────────────────────── */
    .thread {
      position: fixed;
      left: 0;
      top: 52px;
      bottom: 0;
      width: 3px;
      background: linear-gradient(180deg, #C47F00 0%, #F0A500 25%, #C47F00 55%, rgba(196, 127, 0, 0.08) 100%);
      z-index: 40;
      pointer-events: none position:relative
    }

    /* ── NAV ───────────────────────────────────────────────────── */
    .hdr {
      position: sticky;
      top: 0;
      z-index: 100;
      width: 100%;
      background: linear-gradient(180deg, #222 0%, #111 100%);
      box-shadow: 0 3px 0 #000, 0 4px 20px rgba(0, 0, 0, 0.5);
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 28px
    }

    .hdr-name {
      font-size: 15px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.2px
    }

    .hdr-nav {
      display: flex;
      align-items: center;
      gap: 2px
    }

    .nav-item {
      position: relative
    }

    .nav-a {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.72);
      padding: 5px 10px;
      border-radius: 4px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 3px;
      transition: color 0.15s, background 0.15s;
      user-select: none
    }

    .nav-a:hover {
      color: #fff;
      background: rgba(255, 255, 255, 0.1)
    }

    .nav-a .arr {
      font-size: 8px;
      opacity: 0.55;
      margin-top: 1px
    }

    .drop {
      display: none;
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      background: #1c1c1c;
      border: 0.5px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      padding: 6px 0;
      min-width: 200px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
      z-index: 300
    }

    .nav-item:hover .drop {
      display: block
    }

    .drop-g {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #C47F00;
      padding: 6px 14px 2px
    }

    .drop-i {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.6);
      padding: 7px 14px;
      cursor: pointer;
      transition: background 0.12s, color 0.12s
    }

    .drop-i:hover {
      background: rgba(255, 255, 255, 0.07);
      color: #fff
    }

    .drop-hr {
      height: 0.5px;
      background: rgba(255, 255, 255, 0.08);
      margin: 5px 0
    }

    .nav-ver {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.72);
      padding: 5px 10px;
      border-radius: 4px;
      cursor: pointer;
      transition: color 0.15s, background 0.15s
    }

    .nav-ver:hover {
      color: #fff;
      background: rgba(255, 255, 255, 0.1)
    }

    .hdr-cta {
      font-size: 12px;
      font-weight: 600;
      padding: 7px 18px;
      border-radius: 20px;
      background: #C47F00;
      color: #fff;
      border: none;
      cursor: pointer;
      margin-left: 8px;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s
    }

    .hdr-cta:hover {
      background: #D98F00;
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(196, 127, 0, 0.4)
    }

    /* ── PAGE WRAPPER ──────────────────────────────────────────── */
    .page {
      width: 100%;
      padding: 20px 28px 0
    }

    .main {
      width: 80%;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 0
    }

    /* ── CARD SHELL ────────────────────────────────────────────── */
    .card {
      background: #fff;
      border-radius: 12px;
      border: 0.5px solid #D8D3CA;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
      overflow: hidden;
      margin-bottom: 12px;
      transition: box-shadow 0.25s, transform 0.25s
    }

    .card:hover {
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.09);
      transform: translateY(-1px)
    }

    /* ── SCROLL REVEAL ─────────────────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.5s ease, transform 0.5s ease
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0)
    }

    /* ── BANNER ────────────────────────────────────────────────── */
    .banner {
      width: 100%;
      height: 168px;
      background: #0D0D0D;
      position: relative;
      overflow: hidden
    }

    .b-grid {
      position: absolute;
      inset: 0;
      background-image: linear-gradient(rgba(196, 127, 0, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(196, 127, 0, 0.05) 1px, transparent 1px);
      background-size: 40px 40px
    }

    .b-orb1 {
      position: absolute;
      width: 320px;
      height: 320px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(196, 127, 0, 0.22) 0%, transparent 70%);
      top: -130px;
      right: -80px;
      animation: orb-drift 12s ease-in-out infinite alternate
    }

    .b-orb2 {
      position: absolute;
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(196, 127, 0, 0.12) 0%, transparent 70%);
      bottom: -100px;
      left: 20px;
      animation: orb-drift 16s ease-in-out infinite alternate-reverse
    }

    .b-orb3 {
      position: absolute;
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(240, 165, 0, 0.08) 0%, transparent 70%);
      top: 0;
      left: 140px
    }

    @keyframes orb-drift {
      0% {
        transform: translate(0, 0)
      }

      100% {
        transform: translate(20px, 10px)
      }
    }

    .b-line {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, transparent 0%, #C47F00 20%, #F0A500 50%, #C47F00 80%, transparent 100%)
    }

    .b-mark {
      position: absolute;
      bottom: 10px;
      right: 18px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.07)
    }

    .banner svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%
    }

    /* ── PROFILE BODY ──────────────────────────────────────────── */
    .profile-body {
      padding: 0 24px 0
    }

    .avatar-row {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-top: -52px;
      margin-bottom: 18px
    }

    .avatar-wrap {
      position: relative;
      flex-shrink: 0
    }

    .avatar {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      border: 4px solid #fff;
      box-shadow: 0 3px 20px rgba(196, 127, 0, 0.35), 0 2px 8px rgba(0, 0, 0, 0.18);
      overflow: hidden;
      position: relative;
      background: #C47F00;
      transition: box-shadow 0.3s
    }

    .avatar:hover {
      box-shadow: 0 4px 28px rgba(196, 127, 0, 0.5), 0 2px 10px rgba(0, 0, 0, 0.2)
    }

    .avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block
    }

    .avatar-verified {
      position: absolute;
      bottom: 2px;
      right: 2px;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: #4CAF50;
      border: 3px solid #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      color: #fff;
      font-weight: 700;
      box-shadow: 0 2px 8px rgba(76, 175, 80, 0.5);
      z-index: 10;
      overflow: visible
    }

    .avatar-actions {
      display: flex;
      gap: 8px;
      padding-bottom: 6px;
      align-items: center
    }

    .btn-dark {
      font-size: 13px;
      font-weight: 600;
      padding: 8px 22px;
      border-radius: 20px;
      background: #1A1A1A;
      color: #fff;
      border: 1.5px solid #1A1A1A;
      cursor: pointer;
      transition: all 0.2s
    }

    .btn-dark:hover {
      background: transparent;
      color: #C47F00;
      border-color: #C47F00;
      box-shadow: 0 2px 12px rgba(196, 127, 0, 0.2)
    }

    .btn-amber {
      font-size: 13px;
      font-weight: 600;
      padding: 8px 22px;
      border-radius: 20px;
      background: #C47F00;
      color: #fff;
      border: 1.5px solid #C47F00;
      cursor: pointer;
      transition: all 0.2s
    }

    .btn-amber:hover {
      background: #D98F00;
      box-shadow: 0 4px 16px rgba(196, 127, 0, 0.4);
      transform: translateY(-1px)
    }

    /* ── PROFILE NAME / HEADLINE / TAGS / STATS ────────────────── */
    .profile-name {
      font-size: 34px;
      font-weight: 700;
      color: #1A1A1A;
      letter-spacing: -1.2px;
      line-height: 1.05;
      margin-bottom: 6px
    }

    .profile-name .char {
      display: inline-block;
      opacity: 0;
      transform: translateY(28px);
      animation: charUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards
    }

    .profile-name .spc {
      display: inline-block;
      width: 0.22em
    }

    .profile-headline {
      font-size: 14px;
      color: #555;
      margin-bottom: 12px;
      line-height: 1.45
    }

    .profile-headline strong {
      color: #1A1A1A;
      font-weight: 600
    }

    .profile-tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 16px
    }

    .ptag {
      font-size: 11px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 20px;
      background: #FEF3DC;
      color: #7A5200;
      border: 0.5px solid #E8C870;
      cursor: default;
      transition: background 0.15s, transform 0.15s, box-shadow 0.15s
    }

    .ptag:hover {
      background: #FDEAB5;
      transform: translateY(-1px);
      box-shadow: 0 2px 8px rgba(196, 127, 0, 0.15)
    }

    .profile-stats {
      display: flex;
      gap: 0;
      border-top: 0.5px solid #EBEBEB;
      flex-wrap: wrap
    }

    .pstat {
      flex: 1;
      min-width: 20%;
      padding: 14px 10px;
      text-align: center;
      border-right: 0.5px solid #EBEBEB;
      cursor: pointer;
      transition: background 0.15s
    }

    .pstat:last-child {
      border-right: none
    }

    .pstat:hover {
      background: #FAFAF7
    }

    .pstat-val {
      font-size: 19px;
      font-weight: 700;
      color: #1A1A1A;
      letter-spacing: -0.5px;
      line-height: 1
    }

    .pstat-val em {
      font-style: normal;
      color: #C47F00
    }

    .pstat-sup {
      font-size: 11px;
      color: #C47F00;
      font-weight: 700;
      vertical-align: super
    }

    .pstat-key {
      font-size: 10px;
      color: #999;
      margin-top: 3px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.04em
    }

    /* ── VERIFICATION STRIP ────────────────────────────────────── */
    .ver-card {
      background: linear-gradient(135deg, #1A1A1A 0%, #252525 100%);
      border-color: #383838;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 22px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
      gap: 16px position:relative;
      overflow: hidden
    }

    .ver-left {
      display: flex;
      align-items: center;
      gap: 14px;
      flex: 1;
      min-width: 0
    }

    .ver-icon-wrap {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: rgba(196, 127, 0, 0.12);
      border: 0.5px solid rgba(196, 127, 0, 0.25);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 18px;
      color: #C47F00
    }

    .ver-title {
      font-size: 13px;
      font-weight: 600;
      color: #fff;
      margin-bottom: 2px
    }

    .ver-sub {
      font-size: 11px;
      color: rgba(255, 255, 255, 0.38);
      line-height: 1.4
    }

    .ver-badge {
      font-size: 11px;
      font-weight: 600;
      padding: 6px 16px;
      border-radius: 20px;
      background: rgba(76, 175, 80, 0.12);
      color: #5CB85C;
      border: 0.5px solid rgba(76, 175, 80, 0.3);
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
      flex-shrink: 0
    }

    .ver-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #4CAF50;
      animation: ver-pulse 2s ease-in-out infinite
    }

    @keyframes ver-pulse {

      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.4)
      }

      50% {
        box-shadow: 0 0 0 5px rgba(76, 175, 80, 0)
      }
    }

    /* ── CAROUSEL QUOTE ────────────────────────────────────────── */
    .carousel-card {
      background: linear-gradient(135deg, #111 0%, #1C1C1C 60%, #181818 100%);
      border-color: #333
    }

    .cc-body {
      padding: 24px 24px 20px
    }

    .cc-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #C47F00;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 10px
    }

    .cc-label::after {
      content: '';
      flex: 1;
      height: 0.5px;
      background: rgba(255, 255, 255, 0.08)
    }

    .cc-quote {
      font-size: 60px;
      color: rgba(196, 127, 0, 0.22);
      line-height: 0.6;
      margin-bottom: 10px;
      font-family: Georgia, serif;
      display: block
    }

    .cc-text {
      font-size: 20px;
      font-weight: 400;
      color: #fff;
      line-height: 1.6;
      letter-spacing: -0.1px;
      min-height: 88px;
      transition: opacity 0.3s, transform 0.3s;
      font-style: italic
    }

    .cc-text.out {
      opacity: 0;
      transform: translateX(-12px)
    }

    .cc-text.in {
      opacity: 0;
      transform: translateX(12px)
    }

    .cc-text .am {
      color: #F0A500;
      font-weight: 600;
      font-style: normal
    }

    .cc-text .dm {
      color: rgba(255, 255, 255, 0.38);
      font-style: normal
    }

    .cc-nav {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 20px
    }

    .cc-dots {
      display: flex;
      gap: 5px
    }

    .cc-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.2);
      cursor: pointer;
      transition: background 0.2s, transform 0.2s
    }

    .cc-dot.on {
      background: #F0A500;
      transform: scale(1.5)
    }

    .cc-prog {
      flex: 1;
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 1px;
      overflow: hidden
    }

    .cc-bar {
      height: 100%;
      background: #F0A500;
      width: 0;
      transition: width 0.1s linear
    }

    .cc-ctr {
      font-size: 11px;
      color: rgba(255, 255, 255, 0.25)
    }

    /* ── SECTION HEADER ────────────────────────────────────────── */


    .sh-meta {
      font-size: 10px;
      font-weight: 700;
      color: #C47F00;
      margin-bottom: 5px;
      display: flex;
      align-items: center;
      gap: 8px
    }

    .sh-ref {
      color: #C47F00
    }

    .sh-ch {
      color: #999;
      font-weight: 500
    }

    .sh-title {
      font-size: 20px;
      font-weight: 700;
      color: #1A1A1A;
      letter-spacing: -0.3px
    }

    /* ── PATTERN A — PROSE ─────────────────────────────────────── */
    .sec-prose {
      padding: 20px 22px 24px;
      font-size: 14px;
      color: #444;
      line-height: 1.7
    }

    .sec-prose p+p {
      margin-top: 12px
    }

    .sec-prose strong {
      color: #1A1A1A;
      font-weight: 600
    }

    .sec-prose .am {
      color: #C47F00;
      font-weight: 600
    }

    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 14px
    }

    .chip {
      font-size: 10px;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.88);
      background: #1E1C19;
      border: 0.5px solid rgba(255, 255, 255, 0.12);
      border-radius: 20px;
      padding: 4px 11px;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s
    }

    .chip:hover {
      background: rgba(196, 127, 0, 0.15);
      transform: translateY(-1px)
    }

    /* ── PATTERN B — CARD GRID ─────────────────────────────────── */
    .sec-grid {
      padding: 16px 22px 22px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px
    }

    .ic {
      border: 1.5px solid #E8E3DB;
      border-radius: 10px;
      padding: 18px 16px;
      background: #FAFAF8;
      cursor: default;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s, border-color 0.2s;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden position:relative;
      overflow: hidden
    }

    .ic:hover {
      background: #F5F2EC;
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.09), 0 2px 6px rgba(196, 127, 0, 0.06);
      border-color: #C8C0B0
    }

    .ic:hover::before {
      background: linear-gradient(90deg, transparent, rgba(196, 127, 0, 0.3), transparent)
    }

    .ic-label {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      color: #C47F00;
      margin-bottom: 6px;
      letter-spacing: 0.06em
    }

    .ic-title {
      font-size: 13px;
      font-weight: 700;
      color: #1A1A1A;
      margin-bottom: 5px;
      line-height: 1.3
    }

    .ic-desc {
      font-size: 11px;
      color: #666;
      line-height: 1.55;
      flex: 1
    }

    .ic-tag {
      display: inline-block;
      margin-top: 12px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 4px 11px;
      border-radius: 20px;
      background: #1E1C19;
      color: rgba(255, 255, 255, 0.88);
      border: 0.5px solid rgba(255, 255, 255, 0.12);
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s
    }


    /* S03 reveal style */
    .ic-reveal {
      border-left: 2.5px solid #C47F00;
      border-radius: 0 10px 10px 0;
      background: #FFFDF8
    }

    .ic-reveal .ic-label {
      color: #A06800
    }

    .ic-reveal-dim {
      color: #888;
      font-style: italic;
      font-size: 11px;
      margin-bottom: 3px
    }

    .ic-reveal-strong {
      color: #1A1A1A;
      font-size: 13px;
      font-weight: 600
    }

    /* ── HIGHLIGHTS GRID ───────────────────────────────────────── */
    .card-head {
      padding: 20px 24px 0;
      display: flex;
      align-items: center;
      justify-content: space-between
    }

    .card-title {
      font-size: 16px;
      font-weight: 700;
      color: #1A1A1A
    }

    .card-more {
      font-size: 12px;
      color: #C47F00;
      font-weight: 600;
      cursor: pointer
    }

    .hl-body {
      padding: 16px 24px 24px
    }

    .hl-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px
    }

    .hl-card {
      border: 1.5px solid #E8E3DB;
      border-radius: 12px;
      padding: 28px 24px 22px;
      background: #FAFAF8;
      cursor: default;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s, border-color 0.2s
    }

    .hl-card:hover {
      background: #F5F2EC;
      transform: translateY(-3px);
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.09);
      border-color: #C8C0B0
    }

    .hl-card.feat {
      border-color: #C47F00;
      background: #FFFBF2;
      border-width: 2px
    }

    .hl-card.feat:hover {
